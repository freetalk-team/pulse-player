{
  "name": "pulse-player",
  "version": "1.0.2",
  "description": "Modern, lightweight media player",
  "main": "./out/main/index.js",
  "author": {
    "name": "Freetalk Team",
    "email": "team.freetalk@gmail.com",
    "url": "https://www.sipme.io"
  },
  "contributors": [
    {
      "name": "Pavel Patarinski",
      "email": "pavelp.work@gmail.com",
      "url": "https://www.sipme.io/cv/pavel.patarinski"
    }
  ],
  "homepage": "https://www.sipme.io/player",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freetalk-team/pulse-player.git"
  },
  "config": {
    "port": "4321"
  },
  "scripts": {
    "format": "prettier --plugin prettier-plugin-svelte --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev -- --no-sandbox",
    "debug": "electron-vite dev --remote-debugging-port=9222 -- --no-sandbox --dev",
    "build": "electron-vite build",
    "dev:web": "vite --config web.vite.config.mjs",
    "build:web": "vite build --config web.vite.config.mjs",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "build:icon": "cp resources/icon.png build/pulse-player.png && convert build/pulse-player.png -define icon:auto-resize=256,128,64,48,32,16 build/pulse-player.ico",
    "install:wine": "docker run --rm -ti -v ${PWD}:/project electronuserland/builder:wine bash -c 'npm install'",
    "build:wine": "docker run --rm -ti -e ELECTRON_CACHE=/root/.cache/electron -e ELECTRON_BUILDER_CACHE=/root/.cache/electron-builder -v ${PWD}:/project -v $HOME/.wine/.cache/electron:/root/.cache/electron -v $HOME/.wine/.cache/electron-builder:/root/.cache/electron-builder -v $HOME/.wine/.npm:/root/.npm electronuserland/builder:wine bash -c 'npm run build:win'"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/gutter": "^0.19.9",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@emoji-mart/data": "^1.2.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "bonjour-service": "^1.3.0",
    "dompurify": "^3.4.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "emoji-mart": "^5.6.0",
    "fastify": "^5.8.5",
    "ffmpeg-static": "^5.3.0",
    "marked": "^18.0.3",
    "music-metadata-browser": "^2.5.11",
    "node-id3": "^0.2.9",
    "sortablejs": "^1.15.7",
    "source-map-support": "^0.5.21",
    "svelte-portal": "^2.2.1",
    "yaml": "^2.8.3",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.23",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.13.1",
    "module-alias": "^2.3.4",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "sharp": "^0.34.5",
    "svelte": "^5.45.6",
    "svelte-dnd-action": "^0.9.69",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.6",
    "ws": "^8.20.0"
  },
  "volta": {
    "node": "22.22.2"
  }
}
